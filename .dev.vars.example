# Local development secrets for `npx wrangler pages dev .`
# Copy this file to `.dev.vars` (which is gitignored) and fill in your keys.
# In PRODUCTION these are set in the Cloudflare dashboard, NOT in any file.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides:
# ANTHROPIC_MODEL=claude-sonnet-4-6
# APIFY_ACTOR=compass~crawler-google-places
